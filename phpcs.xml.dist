<?xml version="1.0"?>
<ruleset name="Signal &amp; Noise theme — curated WP handbook conformance">
	<description>
		Curated WordPress-handbook ruleset for the FSE theme: security
		(escaping/sanitization), i18n, deprecated/discouraged APIs, and PHP 8.0+
		cross-version compatibility against the declared `Requires PHP` floor.

		Cosmetic/whitespace/Yoda/alignment sniffs are intentionally EXCLUDED — the
		theme has its own consistent tab style; the goal is correctness + security,
		not formatting churn. Note: i18n is a documented non-goal for this single-
		author theme (no textdomain loaded), so the I18n sniff is informational.

		Run:  composer install, then composer exec -- phpcs
	</description>

	<file>.</file>
	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>
	<exclude-pattern>*/assets/*</exclude-pattern>
	<exclude-pattern>*/.git/*</exclude-pattern>
	<!-- .claude/ exclusion is anchored type="relative" (matched against basepath,
	     NOT the absolute path). This theme is developed in a git worktree under
	     `…/.claude/worktrees/…`; a bare `*/.claude/*` matches the ABSOLUTE path and
	     so matched the worktree's own ancestor dir, silently excluding EVERY file
	     locally (a false 0/0) while CI — on a neutral /home/runner path — scanned
	     everything and failed. The relative anchor (`^\.claude/`) only ever matches
	     a `.claude/` at THIS repo's root, never an ancestor — so local matches CI.
	     Always falsification-test a 0/0 (inject a violation, confirm it's reported)
	     before trusting it: exit 0 can mean "scanned nothing." -->
	<exclude-pattern type="relative">^\.claude/</exclude-pattern>


	<arg name="extensions" value="php"/>
	<arg name="basepath" value="."/>
	<arg name="parallel" value="8"/>
	<arg name="colors"/>
	<arg value="sp"/>

	<!-- ── Security: escaping + sanitization (theme is output-heavy) ──── -->
	<rule ref="WordPress.Security"/>

	<!-- ── API hygiene ───────────────────────────────────────────────── -->
	<rule ref="WordPress.WP.DeprecatedFunctions"/>
	<rule ref="WordPress.WP.DeprecatedParameters"/>
	<rule ref="WordPress.WP.DeprecatedClasses"/>
	<rule ref="WordPress.WP.DiscouragedFunctions"/>
	<rule ref="WordPress.WP.GlobalVariablesOverride"/>
	<rule ref="WordPress.PHP.DontExtract"/>

	<!-- ── i18n ──────────────────────────────────────────────────────────
	     Kept ACTIVE for text-domain VALIDATION (catches a typo'd/wrong domain),
	     but MissingTranslatorsComment is excluded: translator comments only help
	     human translators, and this single-author theme produces no translations
	     (documented non-goal — see inc/setup.php). Strings stay wrapped in __()
	     so i18n CAN be enabled later. (Mirrors the plugin's I18n stance.) -->
	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="signal-noise"/>
				<element value="default"/>
			</property>
		</properties>
		<exclude name="WordPress.WP.I18n.MissingTranslatorsComment"/>
	</rule>

	<!-- ── PHP cross-version compatibility against the declared floor ──── -->
	<config name="testVersion" value="8.0-"/>
	<rule ref="PHPCompatibilityWP"/>

	<config name="minimum_wp_version" value="6.4"/>
</ruleset>
