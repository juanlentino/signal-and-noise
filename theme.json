{
	"$schema": "https://schemas.wp.org/wp/6.9/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"defaultGradients": false,
			"palette": [
				{
					"slug": "void",
					"color": "#ffffff",
					"name": "White"
				},
				{
					"slug": "asphalt",
					"color": "#f5f5f5",
					"name": "Smoke"
				},
				{
					"slug": "concrete",
					"color": "#d9d9d9",
					"name": "Concrete"
				},
				{
					"slug": "rust",
					"color": "#666666",
					"name": "Steel"
				},
				{
					"slug": "bone",
					"color": "#000000",
					"name": "Black"
				},
				{
					"slug": "blood",
					"color": "#e00404",
					"name": "Red"
				},
				{
					"slug": "signal",
					"color": "#ff4c47",
					"name": "Signal"
				}
			]
		},
		"typography": {
			"fluid": true,
			"fontFamilies": [
				{
					"fontFamily": "'Bebas Neue', Impact, sans-serif",
					"name": "Bebas Neue",
					"slug": "heading",
					"fontFace": [
						{
							"fontFamily": "Bebas Neue",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/bebas-neue-latin.woff2"]
						}
					]
				},
				{
					"fontFamily": "'DM Mono', 'Courier New', monospace",
					"name": "DM Mono",
					"slug": "body",
					"fontFace": [
						{
							"fontFamily": "DM Mono",
							"fontWeight": "300",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/dm-mono-300-latin.woff2"]
						},
						{
							"fontFamily": "DM Mono",
							"fontWeight": "400",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/dm-mono-400-latin.woff2"]
						},
						{
							"fontFamily": "DM Mono",
							"fontWeight": "500",
							"fontStyle": "normal",
							"fontDisplay": "swap",
							"src": ["file:./assets/fonts/dm-mono-500-latin.woff2"]
						}
					]
				}
			],
			"fontSizes": [
				{ "slug": "small", "size": "0.8rem", "name": "Small" },
				{ "slug": "medium", "size": "1rem", "name": "Medium" },
				{ "slug": "large", "size": "1.25rem", "name": "Large" },
				{ "slug": "x-large", "size": "clamp(2rem, 4vw, 3.5rem)", "name": "Extra Large" },
				{ "slug": "xx-large", "size": "clamp(3rem, 7vw, 6rem)", "name": "Huge" },
				{ "slug": "xxx-large", "size": "clamp(4rem, 10vw, 9rem)", "name": "Massive" }
			]
		},
		"spacing": {
			"spacingScale": { "steps": 0 },
			"spacingSizes": [
				{ "slug": "10", "size": "0.5rem", "name": "Tight" },
				{ "slug": "20", "size": "1rem", "name": "Small" },
				{ "slug": "30", "size": "1.5rem", "name": "Regular" },
				{ "slug": "40", "size": "2.5rem", "name": "Medium" },
				{ "slug": "50", "size": "4rem", "name": "Large" },
				{ "slug": "60", "size": "6rem", "name": "XL" },
				{ "slug": "70", "size": "8rem", "name": "XXL" },
				{ "slug": "80", "size": "12rem", "name": "Huge" }
			],
			"units": ["%", "px", "em", "rem", "vh", "vw"]
		},
		"layout": {
			"contentSize": "720px",
			"wideSize": "1200px"
		},
		"custom": {
			"lineHeight": {
				"tight": 1.1,
				"normal": 1.7
			},
			"letterSpacing": {
				"tight": "-0.02em",
				"wide": "0.15em",
				"ultra": "0.3em"
			}
		}
	},
	"styles": {
		"color": {
			"background": "var(--wp--preset--color--void)",
			"text": "var(--wp--preset--color--bone)"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--body)",
			"fontSize": "var(--wp--preset--font-size--medium)",
			"lineHeight": "1.7",
			"fontWeight": "300"
		},
		"spacing": {
			"blockGap": "var(--wp--preset--spacing--30)"
		},
		"elements": {
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontWeight": "400",
					"lineHeight": "1.1",
					"textTransform": "uppercase"
				},
				"color": {
					"text": "var(--wp--preset--color--bone)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xxx-large)",
					"letterSpacing": "-0.02em"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--xx-large)",
					"letterSpacing": "-0.01em"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--x-large)"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--large)"
				}
			},
			"link": {
				"color": {
					"text": "var(--wp--preset--color--blood)"
				},
				"typography": {
					"textDecoration": "none"
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--signal)"
					},
					"typography": {
						"textDecoration": "underline"
					}
				}
			},
			"button": {
				"color": {
					"background": "var(--wp--preset--color--bone)",
					"text": "var(--wp--preset--color--void)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"textTransform": "uppercase",
					"letterSpacing": "0.15em"
				},
				"border": {
					"radius": "999px"
				},
				"spacing": {
					"padding": {
						"top": "0.9rem",
						"bottom": "0.9rem",
						"left": "2rem",
						"right": "2rem"
					}
				},
				":hover": {
					"color": {
						"background": "var(--wp--preset--color--blood)",
						"text": "var(--wp--preset--color--void)"
					}
				}
			}
		},
		"blocks": {
			"core/separator": {
				"color": {
					"text": "var(--wp--preset--color--concrete)"
				},
				"border": {
					"width": "1px"
				}
			},
			"core/quote": {
				"border": {
					"left": {
						"color": "var(--wp--preset--color--blood)",
						"width": "3px",
						"style": "solid"
					}
				},
				"spacing": {
					"padding": {
						"left": "var(--wp--preset--spacing--30)"
					}
				},
				"typography": {
					"fontStyle": "normal"
				}
			},
			"core/code": {
				"color": {
					"background": "var(--wp--preset--color--asphalt)",
					"text": "var(--wp--preset--color--blood)"
				},
				"border": {
					"radius": "0px",
					"width": "1px",
					"color": "var(--wp--preset--color--concrete)"
				}
			},
			"core/navigation": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--heading)",
					"fontSize": "var(--wp--preset--font-size--medium)",
					"textTransform": "uppercase",
					"letterSpacing": "0.15em"
				}
			}
		}
	},
	"templateParts": [
		{ "name": "header", "title": "Header", "area": "header" },
		{ "name": "footer", "title": "Footer", "area": "footer" }
	],
	"customTemplates": [
		{ "name": "page-about", "title": "About", "postTypes": ["page"] },
		{ "name": "page-services", "title": "Services", "postTypes": ["page"] },
		{ "name": "page-music", "title": "Music", "postTypes": ["page"] },
		{ "name": "page-contact", "title": "Contact", "postTypes": ["page"] },
		{ "name": "page-resume", "title": "Resume / CV", "postTypes": ["page"] },
		{ "name": "page-notes", "title": "Notes Index", "postTypes": ["page"] },
		{ "name": "page-provenance", "title": "Provenance Pillar", "postTypes": ["page"] }
	]
}
